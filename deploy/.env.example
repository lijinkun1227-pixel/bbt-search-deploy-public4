# Supabase（必填）— 只放占位符，真实密钥写在 deploy/.env（不要提交 git）
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_STORAGE_BUCKET=clips

# 可选：前端
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

SOURCE_VIDEO_ROOT=E:/data/source_videos
REDIS_URL=redis://localhost:6379/0

# 前端公网地址（用于 CORS），本地开发填 localhost，线上填 Netlify 地址
PUBLIC_WEB_URL=http://localhost:3000
# 可选：多个前端域名用逗号分隔（Netlify 预览站等）
# CORS_ORIGINS=https://your-site.netlify.app,https://deploy-preview-123--your-site.netlify.app

API_PORT=8000
